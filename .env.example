DATABASE_URL=mysql+pymysql://root:password@localhost:3306/xiaozhi_mcp
SECRET_KEY=请替换为随机密钥_例如_python_-c_import_secrets_print_secrets_token_hex_32
# access token 有效期（分钟），默认 30
ACCESS_TOKEN_EXPIRE_MINUTES=30
# refresh token 有效期（天），默认 7
REFRESH_TOKEN_EXPIRE_DAYS=7
# 是否允许 MCP wss:// 跳过证书校验（仅自签证书场景，默认 false）
MCP_ALLOW_INSECURE=false
# CORS 允许的来源，逗号分隔；* 表示全部
CORS_ORIGINS=*
# 通用 API 限流：格式 "次数/时间窗口"，如 60/minute、1000/hour
API_RATE_LIMIT=60/minute
# MQTT 凭据加密密钥（Fernet），留空则从 SECRET_KEY 派生
MQTT_CRED_KEY=
